# Nexus Platform — Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — server-side ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Encryption ────────────────────────────
# 64-character hex string (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotate ONLY during off-hours. If this is lost, encrypted fields are unreadable.
FIELD_ENCRYPTION_KEY=your_64_char_hex_string_here

# ── Webhook Security ─────────────────────
# Used to sign outbound webhooks + verify inbound
WEBHOOK_SECRET=your_webhook_shared_secret_here

# ── Email (choose one) ────────────────────
SENDGRID_API_KEY=SG.xxxxx
# RESEND_API_KEY=re_xxxxx

# ── SMS (Twilio) ──────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1555xxxxxxx

# ── Billing (Stripe) ──────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ── Slack ─────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Error Monitoring ──────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

